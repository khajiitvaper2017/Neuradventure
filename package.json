{
  "name": "neuradventure",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude data/** --exclude dist/** --tsconfig tsconfig.json src/server/index.ts",
    "dev:frontend": "vite build --watch",
    "start": "tsx --tsconfig tsconfig.json src/server/index.ts",
    "build": "vite build",
    "preview": "tsx scripts/preview.ts",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"*.{json,js,ts}\"",
    "lint": "eslint src && tsc -p tsconfig.json --noEmit",
    "check:config": "tsx scripts/check-configs.ts",
    "check:css": "tsx scripts/check-css-imports.ts",
    "check": "npm run check:config && npm run check:css && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "migrate:appearance-flat": "tsx scripts/migrate-appearance-flat.ts",
    "test-llm": "tsx --tsconfig tsconfig.json src/server/test_llm.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.3",
    "hono": "^4.12.8",
    "openai": "^6.29.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.6.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
