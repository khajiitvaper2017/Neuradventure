{
  "name": "neuradventure",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"*.{json,js,ts}\"",
    "lint": "eslint src/client",
