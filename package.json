{
  "name": "neuradventure",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server/index.ts",
    "dev:frontend": "vite build --watch",
    "start": "tsx --tsconfig tsconfig.json src/server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"*.{json,js,ts}\"",
    "lint": "eslint src && tsc -p tsconfig.json --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test-llm": "tsx --tsconfig tsconfig.json src/server/test_llm.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.7.4",
    "openai": "^4.86.2",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "eslint-plugin-svelte": "^2.46.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-console-forward-plugin": "^2.0.1"
  }
}
